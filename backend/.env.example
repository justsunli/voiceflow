DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=UTC
DJANGO_SITE_ID=1

POSTGRES_DB=voiceflow
POSTGRES_USER=voiceflow
POSTGRES_PASSWORD=voiceflow
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
# Production option (Render + Neon): set DATABASE_URL and ignore POSTGRES_* above
# DATABASE_URL=postgresql://...
# DB_SSL_REQUIRE=1
# DB_CONN_MAX_AGE=600

OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_TRANSCRIPTION_LANGUAGE=
OPENAI_TRANSCRIPTION_PROMPT=
OPENAI_ACTION_MODEL=gpt-4.1-mini
MAX_AUDIO_UPLOAD_BYTES=15728640

CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# Cookie/security settings for cross-site frontend/backend in production
USE_SECURE_COOKIES=0
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
SECURE_SSL_REDIRECT=0

LOGIN_REDIRECT_URL=http://localhost:5173/
LOGOUT_REDIRECT_URL=http://localhost:5173/

GOOGLE_OAUTH_CALLBACK_URL=http://localhost:8000/accounts/google/login/callback/
